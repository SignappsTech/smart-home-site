# ---------------------------------------------------------------------------
# Contact form
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and set the endpoint your contact form POSTs
# to (e.g. Formspree, Web3Forms, Getform). Until it's set, the form shows a
# fallback message instead of submitting. NEXT_PUBLIC_ prefix = exposed to the
# browser, which a static-export client form requires.
NEXT_PUBLIC_FORM_ENDPOINT=
